NEXTAUTH_URL="http://spa.localhost"
# You can generate this secret with this Linux bash command: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Enable webpack polling for file changes in Docker containers
WATCHPACK_POLLING="true"

# Next.js development configuration for Docker
CHOKIDAR_USEPOLLING="true"
CHOKIDAR_INTERVAL="1000"

# Additional environment variables for Docker HMR
NEXT_PUBLIC_API_BASE_URL="http://api.localhost:8000"

# Server-side Keycloak configuration
KEYCLOAK_CLIENT_ID="folkeep-spa"
KEYCLOAK_CLIENT_SECRET=""
NEXT_PUBLIC_KEYCLOAK_URL="http://keycloak.localhost"
NEXT_PUBLIC_KEYCLOAK_REALM="folkeep"

# Docker-specific HMR configuration
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1"
DISABLE_ESLINT_PLUGIN="true"

# Force polling for file watching in Docker
POLLING=true
POLLING_INTERVAL=1000

# WebSocket configuration for HMR
NEXT_WS_PORT=3000

# Disable Turbopack to use Webpack for reliable HMR in Docker
NEXT_TURBOPACK=0

