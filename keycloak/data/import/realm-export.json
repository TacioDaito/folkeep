{
  "realm": "folkeep",
  "displayName": "Folkeep",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "folkeep-spa",
      "name": "Folkeep SPA Client",
      "description": "Public client for the Single Page Application",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "bearerOnly": false,
      "redirectUris": ["http://localhost:3000/api/auth/callback/keycloak,http://localhost:5173/api/auth/callback/keycloak,http://spa.localhost/api/auth/callback/keycloak"],
      "webOrigins": ["http://localhost:3000,http://localhost:5173,http://spa.localhost"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "web-origins"
      ],
      "optionalClientScopes": [
        "address",
        "phone"
      ]
    },
    {
      "clientId": "folkeep-api",
      "name": "Folkeep API Client",
      "description": "Confidential client for the Laravel backend to validate tokens",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "testuser",
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "testpassword",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-folkeep"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "app-user",
        "description": "Standard application user"
      },
      {
        "name": "app-admin",
        "description": "Application administrator"
      }
    ]
  },
  "defaultRoles": [
    "app-user"
  ],
  "scopeMappings": [],
  "smtpServer": {},
  "internationalizationEnabled": false,
  "supportedLocales": [
    "en",
    "pt-BR"
  ],
  "defaultLocale": "en"
}